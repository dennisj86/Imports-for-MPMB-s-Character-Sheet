{
  "dataSources": [
    {
      "category": "classes",
      "locations": [
        "WotC material/pub_20201117_TCoE.js",
        "WotC material/pub_20191119_ERftLW.js",
        "WotC material/pub_20190903_DnDEK_dupl.js",
        "WotC material/pub_20201117-2_TCoE-sidekicks.js",
        "WotC material/ua_20170313_The-Mystic-Class.js",
        "WotC material/ua_20160912_The-Ranger,-Revised.js"
      ],
      "format": "ClassList.<key> = { ... }",
      "reuse": "medium"
    },
    {
      "category": "subclasses",
      "locations": [
        "WotC material/pub_*.js",
        "WotC material/ua_*.js",
        "WotC 2024/pub_20240917_PHB.js"
      ],
      "format": "AddSubClass(classKey, subKey, definition)",
      "reuse": "high_with_adapter"
    },
    {
      "category": "spells",
      "locations": [
        "WotC material/pub_20140818_PHB.js",
        "WotC material/pub_20150416_EE.js",
        "WotC material/pub_20171121_XGtE.js",
        "WotC 2024/pub_20240917_PHB.js"
      ],
      "format": "SpellsList[spellKey] = { ... }",
      "reuse": "high"
    },
    {
      "category": "features",
      "locations": [
        "embedded in ClassList/RaceList/AddSubClass definitions",
        "WotC material/pub_20201117_TCoE.js",
        "WotC material/pub_20181107_LLoK.js"
      ],
      "format": "features objects, AddFeatureChoice calls",
      "reuse": "medium"
    },
    {
      "category": "species_races",
      "locations": [
        "WotC material/pub_20220125_MotM.js",
        "WotC material/pub_20200317_EGtW.js",
        "WotC 2024/pub_20240917_PHB.js"
      ],
      "format": "RaceList[raceKey] = { ... }, AddRacialVariant(...)",
      "reuse": "high_with_adapter"
    },
    {
      "category": "equipment_items",
      "locations": [
        "WotC material/pub_20141209_DMG.js",
        "WotC material/pub_20171121_XGtE.js",
        "WotC material/pub_20201117_TCoE.js"
      ],
      "format": "MagicItemsList/WeaponsList/ArmourList/GearList/AmmoList objects",
      "reuse": "high_for_catalog_medium_for_effects"
    },
    {
      "category": "backgrounds",
      "locations": [
        "WotC material/pub_20140818_PHB.js",
        "WotC material/pub_20201117_TCoE.js",
        "WotC 2024/pub_20240917_PHB.js"
      ],
      "format": "BackgroundList and BackgroundFeatureList objects",
      "reuse": "high"
    }
  ],
  "importModules": [
    {
      "module": "README import workflow",
      "locations": [
        "README.md"
      ],
      "notes": "MPMB import by loading all_WotC_*.js or individual files in the sheet"
    },
    {
      "module": "build aggregation",
      "locations": [
        "gulpfile.js"
      ],
      "notes": "Concatenates published/UA files and writes all_WotC_published.js, all_WotC_unearthed_arcana.js, all_WotC_pub+UA.js"
    },
    {
      "module": "release upload",
      "locations": [
        ".github/workflows/main.yml"
      ],
      "notes": "Uploads prebuilt all_WotC_*.js artifacts; minify step is currently commented out"
    }
  ],
  "transformModules": [
    {
      "module": "dupl_start/dupl_end pruning",
      "location": "gulpfile.js",
      "purpose": "remove duplicated reprint blocks during concat"
    },
    {
      "module": "strip declarations and source/date comments",
      "location": "gulpfile.js",
      "purpose": "normalization of concatenated outputs"
    },
    {
      "module": "pub+UA merge transform",
      "location": "gulpfile.js",
      "purpose": "rewrites variable names/guards when combining published and UA bundles"
    }
  ],
  "characterRelevantModules": [
    {
      "module": "global content registries",
      "locations": [
        "RaceList",
        "ClassList",
        "SpellsList",
        "BackgroundList",
        "BackgroundFeatureList",
        "FeatsList",
        "MagicItemsList",
        "WeaponsList"
      ],
      "notes": "core data for character options and catalogs"
    },
    {
      "module": "option wiring helpers",
      "locations": [
        "AddSubClass",
        "AddRacialVariant",
        "AddFeatureChoice"
      ],
      "notes": "encodes class/subclass/race/feature choice relationships"
    },
    {
      "module": "feature rule hooks",
      "locations": [
        "eval/removeeval/changeeval",
        "calcChanges",
        "spellcastingBonus",
        "spellcastingExtra",
        "spellcastingFactor",
        "spellcastingKnown"
      ],
      "notes": "valuable but tightly coupled to MPMB runtime"
    }
  ],
  "missingCapabilities": [
    "No standalone character state engine",
    "No consistent typed schema/IDs across all entities",
    "No generic rule solver for proficiency bonus, ability modifiers, AC, HP, saves, skills",
    "No independent spell slot/prepared/known validation engine",
    "No adapter API for UI consumption",
    "No test suite for data integrity or rule behavior",
    "No integrated 2024 bundle in current gulp aggregation"
  ],
  "risks": [
    "Heavy coupling to MPMB global runtime APIs (What/How/CurrentSpells/etc.)",
    "Inconsistent field shapes across files (e.g., scores vs scorestxt, source variants)",
    "Reprint duplication and conditional load order complexity",
    "Release artifacts may drift because CI does not rebuild bundles",
    "Mixed 2014 and 2024 content without explicit conflict policy"
  ],
  "recommendedAdapters": [
    "getClasses()",
    "getClassById(id)",
    "getSubclassesForClass(classId)",
    "getSpells(filters)",
    "getFeaturesForClassLevel(classId, level)",
    "getCharacterOptions(context)",
    "getEquipmentCatalog()",
    "getBackgrounds()",
    "getSpecies()",
    "getFeatCatalog()"
  ]
}
